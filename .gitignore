# Virtual environments
.venv/
venv/
env/

# Claude Code project data (BEER v2.0)
.claude/

# Stray PDB files at project root
/*.pdb

# Large data files — must not be committed
BioLiP.txt
*.gz

# Manuscript — personal, not part of the software distribution
manuscript/


# Developer training scripts and caches — not needed by users
scripts/

# model backups — not for distribution
beer/models/v1_backup/
beer/models/backup/

# Backup model weights
beer/models/*.bak

# Head weights are hosted on the GitHub Release and downloaded on first use
# (see beer/models/weights_manifest.json). Never commit them — keeps the repo lean.
beer/models/*.npz

# Build metadata (regenerated at install time)
beer_biophys.egg-info/
*.pdf

# Internal audit reports — never part of the public repo
AUDIT_REPORT.md
CODE_AUDIT_FIXES.md
